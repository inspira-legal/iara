{
  "name": "@iara/orchestrator",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./supervisor": {
      "types": "./src/supervisor.ts",
      "import": "./src/supervisor.ts",
      "require": "./dist/supervisor.cjs"
    },
    "./parser": {
      "types": "./src/parser.ts",
      "import": "./src/parser.ts",
      "require": "./dist/parser.cjs"
    },
    "./discovery": {
      "types": "./src/discovery.ts",
      "import": "./src/discovery.ts",
      "require": "./dist/discovery.cjs"
    },
    "./interpolation": {
      "types": "./src/interpolation.ts",
      "import": "./src/interpolation.ts",
      "require": "./dist/interpolation.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iara/contracts": "workspace:*",
    "@iara/shared": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
