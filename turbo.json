{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["PORT", "VITE_DEV_SERVER_URL", "ELECTRON_RENDERER_PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@iara/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
