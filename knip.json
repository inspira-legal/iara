{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": ["scripts"],
  "workspaces": {
    ".": {
      "ignoreBinaries": ["electron-rebuild"]
    },
    "apps/web": {
      "entry": ["src/**/*.test.{ts,tsx}", "src/routes/**/*.{ts,tsx}"]
    },
    "packages/orchestrator": {
      "includeEntryExports": true
    },
    "packages/shared": {
      "includeEntryExports": true
    }
  }
}
