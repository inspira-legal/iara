{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "ignoreBinaries": ["electron-builder", "electron-rebuild"]
    },
    "scripts": {
      "entry": ["dev-runner.ts", "release/index.ts"]
    },
    "apps/web": {
      "entry": ["src/**/*.test.{ts,tsx}", "src/routes/**/*.{ts,tsx}"]
    },
    "packages/orchestrator": {
      "includeEntryExports": true
    },
    "packages/shared": {
      "includeEntryExports": true
    }
  }
}
