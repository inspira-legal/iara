{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "release-assets/*.AppImage", "label": "Linux AppImage" },
          { "path": "release-assets/*.dmg", "label": "macOS DMG" },
          { "path": "release-assets/*.exe", "label": "Windows Installer" },
          { "path": "release-assets/*.zip", "label": "Archive" },
          { "path": "release-assets/*.blockmap" },
          { "path": "release-assets/latest*.yml" }
        ]
      }
    ]
  ]
}
